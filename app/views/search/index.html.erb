<% content_for :title, 'Search' %>

<div class="mb-6">
  <%= form_with url: search_path, method: :get do |f| %>
    <div class="relative">
      <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
      <%= f.text_field :q,
          value: @query,
          placeholder: "Search teams, players, leagues...",
          autofocus: true,
          class: "w-full bg-gray-800 text-white placeholder-gray-500 rounded-xl
                  pl-12 pr-4 py-4 text-lg focus:outline-none focus:ring-2
                  focus:ring-blue-500 border border-gray-700" %>
    </div>
  <% end %>
</div>

<% if @query.present? && @query.length < 2 %>
  <p class="text-center text-gray-500 py-8">Type at least 2 characters</p>
<% elsif @query.blank? %>
  <div class="text-center py-16 text-gray-600">
    <p class="text-4xl mb-4">🔍</p>
    <p>Search for teams, players or leagues</p>
  </div>

<% elsif @teams.blank? && @players.blank? && @leagues.blank? %>
  <div class="text-center py-16 text-gray-500">
    <p class="text-4xl mb-4">😕</p>
    <p>No results for "<%= @query %>"</p>
  </div>

<% else %>
  <% if @leagues.any? %>
    <div class="mb-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2 px-1">Leagues</h2>
      <div class="bg-gray-900 rounded-xl overflow-hidden">
        <% @leagues.each do |league| %>
          <%= link_to league_path(league), class: "block" do %>
            <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-800
                        last:border-0 hover:bg-gray-800 transition-colors">
              <% if league.logo.present? %>
                <img src="<%= league.logo %>" class="w-8 h-8 object-contain">
              <% end %>
              <div>
                <p class="text-sm font-medium text-gray-100"><%= league.name %></p>
                <p class="text-xs text-gray-500"><%= league.country&.name %></p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @teams.any? %>
    <div class="mb-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2 px-1">Teams</h2>
      <div class="bg-gray-900 rounded-xl overflow-hidden">
        <% @teams.each do |team| %>
          <%= link_to team_path(team), class: "block" do %>
            <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-800
                        last:border-0 hover:bg-gray-800 transition-colors">
              <% if team.logo.present? %>
                <img src="<%= team.logo %>" class="w-8 h-8 object-contain">
              <% else %>
                <div class="w-8 h-8 bg-gray-700 rounded-full"></div>
              <% end %>
              <p class="text-sm font-medium text-gray-100"><%= team.name %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @players.any? %>
    <div class="mb-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2 px-1">Players</h2>
      <div class="bg-gray-900 rounded-xl overflow-hidden">
        <% @players.each do |player| %>
          <%= link_to player_path(player), class: "block" do %>
            <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-800
                        last:border-0 hover:bg-gray-800 transition-colors">
              <% if player.logo.present? %>
                <img src="<%= player.logo %>" class="w-8 h-8 object-contain rounded-full">
              <% else %>
                <div class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center">
                  <span class="text-xs text-gray-400">👤</span>
                </div>
              <% end %>
              <p class="text-sm font-medium text-gray-100"><%= player.name %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
