<% content_for :title, 'Sign in' %>

<div class="auth-page">
  <div class="auth-card">
    <h2 class="auth-title">Sign in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>

      <div class="auth-fields">
        <div>
          <label class="auth-label">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'auth-input' %>
        </div>

        <div>
          <label class="auth-label">Password</label>
          <%= f.password_field :password, autocomplete: 'current-password', class: 'auth-input' %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="auth-remember">
            <%= f.check_box :remember_me, class: 'auth-remember-checkbox' %>
            <label class="auth-remember-label">Remember me</label>
          </div>
        <% end %>

        <%= f.submit 'Sign in', class: 'auth-submit' %>
      </div>
    <% end %>

    <p class="auth-footer">
      Don't have an account?
      <%= link_to 'Sign up', new_registration_path(resource_name), class: 'auth-switch-link' %>
    </p>
  </div>
</div>
