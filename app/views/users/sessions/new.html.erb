<% content_for :title, 'Sign in' %>

<div class="min-h-[60vh] flex items-center justify-center px-4">
  <div class="bg-gray-900 rounded-xl p-6 w-full max-w-sm">
    <h2 class="text-xl font-bold text-white mb-6 text-center">Sign in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= render "users/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <div>
          <label class="block text-xs text-gray-400 mb-1">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: 'email',
              class: 'w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500' %>
        </div>

        <div>
          <label class="block text-xs text-gray-400 mb-1">Password</label>
          <%= f.password_field :password, autocomplete: 'current-password',
              class: 'w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500' %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: 'w-4 h-4 rounded border-gray-700 bg-gray-800 text-blue-600' %>
            <label class="text-sm text-gray-400">Remember me</label>
          </div>
        <% end %>

        <%= f.submit 'Sign in',
            class: 'w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 rounded-lg text-sm transition-colors cursor-pointer' %>
      </div>
    <% end %>

    <p class="text-center text-sm text-gray-500 mt-4">
      Don't have an account?
      <%= link_to 'Sign up', new_registration_path(resource_name), class: 'text-blue-400 hover:text-blue-300 transition-colors' %>
    </p>
  </div>
</div>
