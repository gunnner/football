<% content_for :title, @team.name %>

<div class="bg-gray-900 rounded-xl p-6 mb-6">
  <div class="flex items-center gap-4">
    <% if @team.logo.present? %>
      <img src="<%= @team.logo %>" alt="<%= @team.name %>"
           class="w-16 h-16 object-contain">
    <% end %>
    <h1 class="text-2xl font-bold text-white"><%= @team.name %></h1>
  </div>
</div>

<div class="bg-gray-900 rounded-xl overflow-hidden">
  <div class="px-4 py-3 border-b border-gray-800">
    <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider">
      Recent Matches
    </h2>
  </div>

  <% if @matches.blank? %>
    <p class="text-center text-gray-500 py-8">No matches found</p>
  <% else %>
    <% @matches.each do |match| %>
      <%= link_to match_path(match), class: "block" do %>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-800
                    last:border-0 hover:bg-gray-800 transition-colors">
          <div class="flex-1 grid grid-cols-3 items-center gap-2">
            <span class="text-sm text-right <%= match.home_team_id.eql?(@team.id) ? 'text-white font-semibold' : 'text-gray-400' %>">
              <%= match.home_team.name %>
            </span>
            <div class="text-center">
              <% if match.finished? || match.live? %>
                <span class="text-sm font-bold text-white">
                  <%= match.score_current.presence || '-' %>
                </span>
              <% else %>
                <span class="text-xs text-gray-500">
                  <%= match.date.strftime("%d %b %H:%M") %>
                </span>
              <% end %>
            </div>
            <span class="text-sm <%= match.away_team_id.eql?(@team.id) ? 'text-white font-semibold' : 'text-gray-400' %>">
              <%= match.away_team.name %>
            </span>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
