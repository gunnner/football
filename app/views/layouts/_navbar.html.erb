<nav class="navbar">
  <div class="navbar-inner">
    <div class="navbar-row" data-controller="search-bar">

      <%# Left: logo %>
      <div class="navbar-left">
        <%= link_to root_path, class: "navbar-logo" do %>
          <span class="navbar-logo-icon">⚽</span>
          <span class="navbar-logo-name">Football</span>
        <% end %>
      </div>

      <%# Right: search + user %>
      <div class="navbar-right">

        <%# Search %>
        <div class="navbar-search-wrap">
          <div class="navbar-search-positioner">
            <div class="navbar-search-form-wrap"
                 data-search-bar-target="form">
              <div class="navbar-search-input-row">
                <input type="text"
                       placeholder="Search teams, players, leagues..."
                       data-search-bar-target="input"
                       data-action="input->search-bar#onInput keydown->search-bar#onKeydown"
                       class="navbar-search-input" />
                <button type="button"
                        data-action="click->search-bar#close"
                        class="navbar-search-clear">
                  <svg class="navbar-search-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </div>

            <div data-search-bar-target="dropdown" class="navbar-search-dropdown"></div>
          </div>

          <button data-action="click->search-bar#open"
                  data-search-bar-target="button"
                  class="navbar-search-btn">
            <svg class="navbar-search-btn-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </button>
        </div>

        <% if user_signed_in? %>
          <div class="navbar-auth">
            <span class="navbar-username">
              <%= current_user.first_name.presence || current_user.email %>
            </span>
            <%= button_to 'Sign Out',
                          destroy_user_session_path,
                          method: :delete,
                          class: "navbar-signout-btn" %>
          </div>
        <% else %>
          <div class="navbar-auth">
            <%= link_to 'Sign In', new_user_session_path, class: "navbar-signin-link" %>
            <%= link_to 'Sign Up', new_user_registration_path, class: "navbar-signup-link" %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</nav>
