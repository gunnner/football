<nav class="bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-14">

      <div class="flex items-center gap-8">
        <%= link_to root_path, class: "flex items-center gap-2 text-white font-bold text-lg" do %>
          <span class="text-2xl">⚽</span>
          <span class="hidden sm:block">Football</span>
        <% end %>

        <div class="flex items-center gap-1">
          <%= nav_link 'Matches', matches_path %>
          <%= nav_link 'Leagues', leagues_path %>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <%= link_to search_path, class: "text-gray-400 hover:text-white transition-colors" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        <% end %>

        <% if user_signed_in? %>
          <div class="flex items-center gap-3">
            <span class="text-gray-400 text-sm hidden sm:block">
              <%= current_user.first_name.presence || current_user.email %>
            </span>
            <%= link_to 'Sign Out',
                        destroy_user_session_path,
                        data: { turbo_method: :delete },
                        class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          </div>
        <% else %>
          <div class="flex items-center gap-3">
            <%= link_to 'Sign In',
                        new_user_session_path,
                        class: "text-sm text-gray-400 hover:text-white transition-colors" %>
            <%= link_to 'Sign Up',
                        new_user_registration_path,
                        class: "text-sm bg-blue-600 hover:bg-blue-500 text-white px-3 py-1.5 rounded-md transition-colors" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</nav>
