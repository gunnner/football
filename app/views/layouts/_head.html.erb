<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="application-name" content="Football">
<meta name="mobile-web-app-capable" content="yes">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>
<%= yield :head %>

<link rel="icon" href="/icon.png" type="image/png">
<link rel="icon" href="/icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/icon.png">

<%= vite_client_tag                   %>
<%= vite_stylesheet_tag 'application' %>
<%= vite_javascript_tag 'react.jsx'   %>
<%= vite_javascript_tag 'application' %>

<%= Sentry.get_trace_propagation_meta.html_safe %>
<meta name="sentry-dsn"
      content="<%= Rails.env.production? || Rails.env.staging? ? ENV['SENTRY_DSN'] : ENV['SENTRY_JS_DSN'] %>">
<meta name="rails-env" content="<%= Rails.env %>">
