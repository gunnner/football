<div class="flex items-center gap-3 py-2 border-b border-gray-800 last:border-0">
  <span class="text-gray-400 text-sm w-8 text-right flex-shrink-0">
    <%= event.time %>'
  </span>

  <span class="text-lg flex-shrink-0">
    <%= event_icon(event.event_type) %>
  </span>

  <div class="flex-1">
    <p class="text-sm text-gray-100"><%= event.player_name %></p>
    <p class="text-xs text-gray-500"><%= event.team_name   %></p>
  </div>
</div>
