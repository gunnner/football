<% content_for :title, "#{@match.home_team.name} vs #{@match.away_team.name}" %>

<div data-controller="match" data-match-id-value="<%= @match.id %>">
  <div class="bg-gray-900 rounded-xl p-6 mb-4">
    <p class="text-center text-gray-500 text-sm mb-4">
      <% tour = @match.round.split(' ').last.to_i %>
      <%= @match.league.name %> · <%= tour.zero? ? @match.round : "Tour - #{tour}" %>
    </p>

    <div class="grid grid-cols-3 items-center gap-4">
      <div class="text-center">
        <p class="font-bold text-xl text-white"><%= @match.home_team.name %></p>
      </div>

      <div class="text-center" id="match_score_<%= @match.id %>">
        <% if @match.live? %>
          <p class="text-4xl font-bold text-white"><%= @match.score_current || "0 - 0" %></p>
          <p class="text-red-400 text-sm font-medium animate-pulse mt-1"><%= @match.clock %>'</p>
        <% elsif @match.finished? %>
          <p class="text-4xl font-bold text-white"><%= @match.score_current || "-" %></p>
          <p class="text-gray-500 text-sm mt-1">Finished</p>
        <% else %>
          <p class="text-gray-400 text-2xl"><%= @match.date.strftime("%H:%M") %></p>
          <p class="text-gray-600 text-sm mt-1"><%= @match.status %></p>
        <% end %>
      </div>

      <div class="text-center">
        <p class="font-bold text-xl text-white"><%= @match.away_team.name %></p>
      </div>
    </div>
  </div>

  <%# Tabs %>
  <div data-controller="tabs">
    <div class="flex gap-1 mb-4 bg-gray-900 p-1 rounded-lg">
      <button data-tabs-target="tab"
              data-action="click->tabs#switch"
              class="flex-1 py-2 text-sm font-medium rounded-md bg-gray-700 text-white">
        Events
      </button>
      <button data-tabs-target="tab"
              data-action="click->tabs#switch"
              class="flex-1 py-2 text-sm font-medium rounded-md text-gray-400">
        Statistics
      </button>
      <button data-tabs-target="tab"
              data-action="click->tabs#switch"
              class="flex-1 py-2 text-sm font-medium rounded-md text-gray-400">
        Lineups
      </button>
    </div>

    <%# Events %>
    <div data-tabs-target="panel" class="bg-gray-900 rounded-xl p-4">
      <% if @match_events.blank? %>
        <p class="text-center text-gray-500 py-8">No events yet</p>
      <% else %>
        <% @match_events.sort_by(&:time).each do |event| %>
          <%= render 'event', event: event %>
        <% end %>
      <% end %>
    </div>

    <%# Statistics %>
    <div data-tabs-target="panel" class="hidden bg-gray-900 rounded-xl p-4">
      <% if @match_statistics.blank? %>
        <p class="text-center text-gray-500 py-8">No statistics yet</p>
      <% else %>
        <% stats_by_name = @match_statistics.group_by(&:display_name) %>
        <% stats_by_name.each do |name, stats| %>
          <% home_stat = stats.find { it.team_external_id.eql?(@match.home_team.external_id) } %>
          <% away_stat = stats.find { it.team_external_id.eql?(@match.away_team.external_id) } %>

          <% if name.in?(MatchStatistic::INTEGER_METRICS) %>
            <% home_val = home_stat&.value&.to_i %>
            <% away_val = away_stat&.value&.to_i %>
          <% elsif name == 'Possession' %>
            <% home_val = "#{home_stat&.value}%" %>
            <% away_val = "#{away_stat&.value}%" %>
          <% else %>
            <% home_val = home_stat&.value %>
            <% away_val = away_stat&.value %>
          <% end %>

          <div class="flex items-center gap-3 py-2 border-b border-gray-800 last:border-0">
            <span class="flex-1 text-right text-sm text-gray-100"><%= home_val || '-' %></span>
            <span class="w-40 text-center text-xs text-gray-500"><%= name %></span>
            <span class="flex-1 text-left text-sm text-gray-100"><%= away_val || '-' %></span>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Lineups %>
    <div data-tabs-target="panel" class="hidden bg-gray-900 rounded-xl p-4">
      <% if @match_lineups.blank? %>
        <p class="text-center text-gray-500 py-8">No lineups yet</p>
      <% else %>
        <div class="grid grid-cols-2 gap-4">
          <% @match_lineups.each do |lineup| %>
            <div>
              <p class="text-sm font-semibold text-gray-300 mb-2">
                <%= lineup.team_name %>
                <span class="text-gray-500 text-xs ml-1"><%= lineup.formation %></span>
              </p>
              <% Array(lineup.initial_lineup).each do |row| %>
                <div class="flex gap-2 mb-1">
                  <% Array(row).each do |player| %>
                    <span class="text-xs text-gray-400">
                      <%= player['number'] %>. <%= player['name'] %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

</div>
