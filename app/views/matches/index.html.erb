<% content_for :title, 'Matches' %>

<div class="flex items-center gap-2 mb-6">
  <%= link_to 'All',      matches_path,                     class: filter_tab_class(params[:status].blank?)           %>
  <%= link_to 'Live',     matches_path(status: 'live'),     class: filter_tab_class(params[:status].eql?('live'))     %>
  <%= link_to 'Today',    matches_path(status: 'today'),    class: filter_tab_class(params[:status].eql?('today'))    %>
  <%= link_to 'Finished', matches_path(status: 'finished'), class: filter_tab_class(params[:status].eql?('finished')) %>
  <%= link_to 'Upcoming', matches_path(status: 'upcoming'), class: filter_tab_class(params[:status].eql?('upcoming')) %>
</div>

<% if @matches.blank? %>
  <div class="text-center py-16 text-gray-500">
    <p class="text-4xl mb-4">⚽</p>
    <p class="text-lg">No matches found</p>
  </div>
<% else %>
  <div class="space-y-2" id="matches-list">
    <% @matches.group_by { it.league }.each do |league, matches| %>
      <% cache [league, matches.map(&:cache_key_with_version).sort, params[:status]] do %>

        <div class="bg-gray-800 px-4 py-2 rounded-t-lg flex items-center gap-2">
          <span class="text-sm font-semibold text-gray-300"><%= league.name %></span>
        </div>

        <% matches.each do |match| %>
          <% cache match do %>
            <div class="bg-gray-900 hover:bg-gray-800 transition-colors
                        border-b border-gray-800 last:rounded-b-lg last:border-0">
              <div class="flex items-center px-4 py-3">
                <div class="flex-1 flex items-center justify-end gap-2">
                  <%= link_to match.home_team.name, team_path(match.home_team),
                      class: "text-sm font-medium text-gray-100 hover:text-blue-400 transition-colors" %>
                  <% if match.home_team.logo.present? %>
                    <img src="<%= match.home_team.logo %>" class="w-6 h-5 object-contain flex-shrink-0">
                  <% end %>
                </div>

                <div class="w-32 text-center mx-4">
                  <%= link_to match_path(match), class: "block py-1" do %>
                    <% if match.finished? %>
                      <span class="text-white font-bold text-sm">
                        <%= match.score_current.presence || '-' %>
                      </span>
                    <% elsif match.live? %>
                      <span class="text-white font-bold text-sm">
                        <%= match.score_current || '0 - 0' %>
                      </span>
                      <span class="text-red-400 text-xs block animate-pulse">
                        <%= match.clock %>'
                      </span>
                    <% else %>
                      <span class="text-gray-400 text-sm">
                        <%= match.date.strftime("%H:%M") %>
                      </span>
                      <span class="text-gray-600 text-xs block"><%= match.status %></span>
                    <% end %>
                  <% end %>
                </div>

                <div class="flex-1 flex items-center justify-start gap-2">
                  <% if match.away_team.logo.present? %>
                    <img src="<%= match.away_team.logo %>" class="w-6 h-5 object-contain flex-shrink-0">
                  <% end %>
                  <%= link_to match.away_team.name, team_path(match.away_team),
                      class: "text-sm font-medium text-gray-100 hover:text-blue-400 transition-colors" %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
