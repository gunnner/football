<% content_for :title, @player.name %>

<div class="bg-gray-900 rounded-xl p-6 mb-6">
  <div class="flex items-center gap-4">
    <% if @player.logo.present? %>
      <img src="<%= @player.logo %>" alt="<%= @player.name %>"
           class="w-16 h-16 object-contain rounded-full">
    <% else %>
      <div class="w-16 h-16 bg-gray-700 rounded-full flex items-center justify-center">
        <span class="text-2xl">👤</span>
      </div>
    <% end %>

    <div>
      <h1 class="text-2xl font-bold text-white"><%= @player.name %></h1>
      <% if @player.player_profile.present? %>
        <p class="text-gray-400 text-sm mt-1">
          <%= @player.player_profile.main_position %>
          <% if @player.player_profile.current_club.present? %>
            · <%= @player.player_profile.current_club %>
          <% end %>
        </p>
      <% end %>
    </div>
  </div>

  <% if @player.player_profile.present? %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6">
      <% if @player.player_profile.birth_date.present? %>
        <div>
          <p class="text-xs text-gray-500 uppercase">Born</p>
          <p class="text-sm text-gray-100 mt-1"><%= @player.player_profile.birth_date %></p>
        </div>
      <% end %>
      <% if @player.player_profile.citizenship.present? %>
        <div>
          <p class="text-xs text-gray-500 uppercase">Nationality</p>
          <p class="text-sm text-gray-100 mt-1"><%= @player.player_profile.citizenship %></p>
        </div>
      <% end %>
      <% if @player.player_profile.height.present? %>
        <div>
          <p class="text-xs text-gray-500 uppercase">Height</p>
          <p class="text-sm text-gray-100 mt-1"><%= @player.player_profile.height %></p>
        </div>
      <% end %>
      <% if @player.player_profile.foot.present? %>
        <div>
          <p class="text-xs text-gray-500 uppercase">Foot</p>
          <p class="text-sm text-gray-100 mt-1"><%= @player.player_profile.foot&.capitalize %></p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @stats.any? %>
  <div class="bg-gray-900 rounded-xl overflow-hidden mb-6">
    <div class="px-4 py-3 border-b border-gray-800">
      <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider">Statistics</h2>
    </div>
    <% @stats.each do |stat| %>
      <div class="px-4 py-3 border-b border-gray-800 last:border-0">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm text-gray-400"><%= stat.league %> <%= stat.season %></span>
          <span class="text-xs text-gray-500"><%= stat.club %></span>
        </div>
        <div class="grid grid-cols-4 gap-2 text-center">
          <div>
            <p class="text-lg font-bold text-white"><%= stat.goals %></p>
            <p class="text-xs text-gray-500">Goals</p>
          </div>
          <div>
            <p class="text-lg font-bold text-white"><%= stat.assists %></p>
            <p class="text-xs text-gray-500">Assists</p>
          </div>
          <div>
            <p class="text-lg font-bold text-white"><%= stat.games_played %></p>
            <p class="text-xs text-gray-500">Games</p>
          </div>
          <div>
            <p class="text-lg font-bold text-white"><%= stat.yellow_cards %></p>
            <p class="text-xs text-gray-500">Yellow</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if @transfers.any? %>
  <div class="bg-gray-900 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-800">
      <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider">Transfers</h2>
    </div>
    <% @transfers.each do |transfer| %>
      <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-800 last:border-0">
        <span class="text-xs text-gray-500 w-12"><%= transfer.season %></span>
        <div class="flex-1 flex items-center gap-2">
          <span class="text-sm text-gray-400"><%= transfer.team_from %></span>
          <span class="text-gray-600">→</span>
          <span class="text-sm text-gray-100"><%= transfer.team_to %></span>
        </div>
        <% if transfer.fee.present? %>
          <span class="text-xs text-green-400"><%= transfer.fee %></span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
