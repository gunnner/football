<% content_for :title, 'Players' %>

<h1 class="text-2xl font-bold text-white mb-6">Players</h1>

<div class="bg-gray-900 rounded-xl overflow-hidden">
  <% @players.each do |player| %>
    <%= link_to player_path(player), class: "block" do %>
      <div class="flex items-center gap-4 px-4 py-3 border-b border-gray-800
                  last:border-0 hover:bg-gray-800 transition-colors">
        <% if player.logo.present? %>
          <img src="<%= player.logo %>" alt="<%= player.name %>"
               class="w-8 h-8 object-contain rounded-full">
        <% else %>
          <div class="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center">
            <span class="text-xs text-gray-400">👤</span>
          </div>
        <% end %>
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-100"><%= player.name %></p>
        </div>
        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    <% end %>
  <% end %>
</div>
